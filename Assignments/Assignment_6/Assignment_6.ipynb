        "\n",
        "Context:\n",
        "{context}\n",
        "\n",
        "Question:\n",
        "{query}\n",
        "\n",
        "Answer:\n",
        "\"\"\"\n",
        "\n",
        "    result = llm(prompt, max_new_tokens=150)\n",
        "    return result[0]['generated_text']"
